# Copy this file to .env and fill in real values before running the project.
#   cp .env.example .env

# When using `docker compose up`, leave the host/user/password/db name below
# matching the POSTGRES_* values — the app will talk to the "db" container.
DATABASE_URL="postgresql://myuser:mypassword123@localhost:5432/mydatabase?schema=public"

# Used by docker compose to create the local Postgres container
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword123
POSTGRES_DB=mydatabase

JWT_SECRET=change-me
KHALTI_SECRET_KEY=

HAMRO_PAY_CLIENT_ID=
HAMRO_PAY_CLIENT_API_KEY=
HAMRO_PAY_SECRET=
HAMRO_PAY_MERCHANT_ID=
HAMRO_PAY_BASE_URL="https://uat-payclient.hamropatro.com"
HAMRO_PAY_GATEWAY_URL="https://uat-checkout-pay.hamropatro.com"

EMAIL_USER=
EMAIL_PASS=
ADMIN_USER=

NEXT_PUBLIC_APP_URL="http://localhost:3000"
